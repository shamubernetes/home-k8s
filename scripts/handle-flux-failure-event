#!/usr/bin/env bash
# Backticks and dollar expressions below are intentional Markdown or event data.
# shellcheck disable=SC2016
set -euo pipefail

if (( $# != 1 )); then
  printf 'usage: %s <github-event.json>\n' "$0" >&2
  exit 1
fi

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}
need jq

event_file=$1
event_payload=$(jq -c '.client_payload' "$event_file")
EVENT_KIND=$(jq -r '.involvedObject.kind // empty' <<<"$event_payload")
EVENT_NAME=$(jq -r '.involvedObject.name // empty' <<<"$event_payload")
EVENT_NAMESPACE=$(jq -r '.involvedObject.namespace // empty' <<<"$event_payload")
EVENT_MESSAGE=$(jq -r '.message // empty' <<<"$event_payload")
EVENT_REASON=$(jq -r '.reason // empty' <<<"$event_payload")
EVENT_TIMESTAMP=$(jq -r '.timestamp // empty' <<<"$event_payload")
revision=$(
  jq -r '
    .metadata["kustomize.toolkit.fluxcd.io/revision"]
    // .metadata["helm.toolkit.fluxcd.io/revision"]
    // "unknown"
  ' <<<"$event_payload"
)

case "$EVENT_KIND" in
  Kustomization|HelmRelease) ;;
  *)
    printf 'unsupported Flux object kind: %s\n' "$EVENT_KIND" >&2
    exit 1
    ;;
esac

dns_name='^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$'
if [[ ! $EVENT_NAME =~ $dns_name ]]; then
  printf 'invalid Flux object name: %s\n' "$EVENT_NAME" >&2
  exit 1
fi
if [[ ! $EVENT_NAMESPACE =~ $dns_name ]]; then
  printf 'invalid Flux object namespace: %s\n' "$EVENT_NAMESPACE" >&2
  exit 1
fi

issue_title="[Flux Failure] ${EVENT_KIND}/${EVENT_NAME} in ${EVENT_NAMESPACE}"
issue_body=$(mktemp)
trap 'rm -f "$issue_body"' EXIT

write_new_issue() {
  {
    printf '## Flux Resource Failure\n\n'
    printf 'A Flux resource has failed to reconcile and requires attention.\n\n'
    printf '### Resource Details\n\n'
    printf '| Property | Value |\n'
    printf '|----------|-------|\n'
    printf '| **Kind** | `%s` |\n' "$EVENT_KIND"
    printf '| **Name** | `%s` |\n' "$EVENT_NAME"
    printf '| **Namespace** | `%s` |\n' "$EVENT_NAMESPACE"
    printf '| **Reason** | `%s` |\n' "$EVENT_REASON"
    printf '| **Timestamp** | %s |\n' "$EVENT_TIMESTAMP"
    printf '| **Revision** | `%s` |\n\n' "$revision"
    printf '### Error Message\n\n```\n%s\n```\n\n' "$EVENT_MESSAGE"
    printf '### Suggested Actions\n\n'
    printf '1. Check the resource status:\n'
    printf '   ```bash\n'
    printf '   kubectl describe %s %s -n %s\n' "$EVENT_KIND" "$EVENT_NAME" "$EVENT_NAMESPACE"
    printf '   ```\n'
    printf '2. Check Flux controller logs:\n'
    printf '   ```bash\n'
    if [[ $EVENT_KIND == Kustomization ]]; then
      printf '   kubectl logs -n flux-system deployment/kustomize-controller --tail=100\n'
    else
      printf '   kubectl logs -n flux-system deployment/helm-controller --tail=100\n'
    fi
    printf '   ```\n'
    printf '3. Check the Flux status:\n'
    printf '   ```bash\n'
    printf '   flux get all -A\n'
    printf '   ```\n\n'
    printf '%s\n' '---'
    printf '_This issue was automatically created by Flux notification._\n'
  } > "$issue_body"
}

write_recurring_comment() {
  {
    printf '## Recurring Failure\n\n'
    printf 'This Flux resource has failed again.\n\n'
    printf '**Timestamp:** %s\n' "$EVENT_TIMESTAMP"
    printf '**Reason:** `%s`\n\n' "$EVENT_REASON"
    printf '### Error Message\n\n```\n%s\n```\n\n' "$EVENT_MESSAGE"
    printf '_This comment was automatically generated by Flux._\n'
  } > "$issue_body"
}

write_new_issue
if [[ ${FLUX_FAILURE_RENDER_ONLY:-false} == true ]]; then
  printf '%s\n' "$issue_title"
  cat "$issue_body"
  exit 0
fi

need gh
: "${GH_REPO:?GH_REPO must identify the target repository}"
existing_issue=$(
  gh issue list \
    --repo "$GH_REPO" \
    --state open \
    --search "${issue_title} in:title" \
    --json number \
    --jq '.[0].number // empty'
)

if [[ -n $existing_issue ]]; then
  write_recurring_comment
  gh issue comment \
    --repo "$GH_REPO" \
    "$existing_issue" \
    --body-file "$issue_body"
  exit 0
fi

gh issue create \
  --repo "$GH_REPO" \
  --title "$issue_title" \
  --label 'flux/failure' \
  --body-file "$issue_body"
