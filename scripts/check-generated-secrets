#!/usr/bin/env bash
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
all_tracked="${tmpdir}/all-tracked"
talos_tracked="${tmpdir}/talos-tracked"
tracked_configs="${tmpdir}/tracked-configs"
sensitive_files="${tmpdir}/sensitive-files"

git ls-files > "$all_tracked"

if grep '^talos/clusterconfig/' "$all_tracked" > "$talos_tracked"; then
  :
else
  rc=$?
  if (( rc != 1 )); then
    exit "$rc"
  fi
  : > "$talos_tracked"
fi

if grep -vFx 'talos/clusterconfig/.gitignore' "$talos_tracked" > "$tracked_configs"; then
  :
else
  rc=$?
  if (( rc != 1 )); then
    exit "$rc"
  fi
  : > "$tracked_configs"
fi

if [[ -s $tracked_configs ]]; then
  printf 'Generated Talos cluster configuration must not be tracked:\n' >&2
  while IFS= read -r file; do
    printf '  %s\n' "$file" >&2
  done < "$tracked_configs"
  exit 1
fi

if grep -Ei '(^|/)(kubeconfig|talosconfig|[^/]+\.(key|pem|crt|p12|pfx))$' "$all_tracked" > "$sensitive_files"; then
  :
else
  rc=$?
  if (( rc != 1 )); then
    exit "$rc"
  fi
  : > "$sensitive_files"
fi

if [[ -s $sensitive_files ]]; then
  printf 'Sensitive client configuration or key material must not be tracked:\n' >&2
  while IFS= read -r file; do
    printf '  %s\n' "$file" >&2
  done < "$sensitive_files"
  exit 1
fi

git check-ignore --quiet --no-index talos/clusterconfig/titans-newnode.yaml
if git check-ignore --quiet --no-index talos/clusterconfig/.gitignore; then
  echo 'talos/clusterconfig/.gitignore must remain trackable' >&2
  exit 1
fi

printf 'ok: generated credentials are not tracked and future Talos output is ignored\n'
