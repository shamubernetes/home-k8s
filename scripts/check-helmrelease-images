#!/usr/bin/env bash
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

baseline="${repo_root}/scripts/helm-image-pin-baseline.txt"
skips="${repo_root}/scripts/helm-image-validation-skips.txt"
for required in "$baseline" "$skips"; do
  [[ -f $required ]] || {
    printf 'required Helm image validation policy is missing: %s\n' "$required" >&2
    exit 1
  }
done

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
yaml_files="${tmpdir}/yaml-files"
apps_unsorted="${tmpdir}/apps-unsorted"
all_apps="${tmpdir}/all-apps"
apps="${tmpdir}/apps"
actual="${tmpdir}/actual"
expected="${tmpdir}/expected"
: > "$apps_unsorted"
: > "$actual"

if git grep -l -E \
  '^[[:space:]]*kind:[[:space:]]*HelmRelease[[:space:]]*$' -- \
  'kubernetes/apps/**/*.yaml' 'kubernetes/apps/**/*.yml' > "$yaml_files"; then
  :
else
  grep_rc=$?
  if (( grep_rc != 1 )); then
    echo 'failed to discover tracked HelmRelease candidate files' >&2
    exit 1
  fi
fi
if [[ ! -s $yaml_files ]]; then
  echo 'no tracked HelmRelease candidate files found' >&2
  exit 1
fi

# Parse each exact-line candidate once with bounded concurrency. This preserves
# fail-closed full-tree YAML validation, filters textual false positives, and
# avoids the original pair of sequential yq launches per candidate.
helmrelease_files="${tmpdir}/helmrelease-files"
mapfile -t candidate_files < "$yaml_files"
discovery_jobs=${HELM_IMAGE_DISCOVERY_JOBS:-8}
[[ $discovery_jobs =~ ^[1-9][0-9]*$ ]] || {
  printf 'HELM_IMAGE_DISCOVERY_JOBS must be a positive integer: %s\n' \
    "$discovery_jobs" >&2
  exit 1
}

run_discovery() {
  local file=$1 index=$2 rc
  if yq -r -N 'select(.kind == "HelmRelease") | filename' "$file" \
    > "${tmpdir}/discover-${index}.out" \
    2> "${tmpdir}/discover-${index}.err"; then
    rc=0
  else
    rc=$?
  fi
  printf '%s\n' "$rc" > "${tmpdir}/discover-${index}.rc"
}

discovery_index=0
for file in "${candidate_files[@]}"; do
  run_discovery "$file" "$discovery_index" &
  discovery_index=$((discovery_index + 1))
  if (( discovery_index % discovery_jobs == 0 )); then
    wait
  fi
done
wait

: > "$helmrelease_files"
for (( index = 0; index < discovery_index; index++ )); do
  rc=$(< "${tmpdir}/discover-${index}.rc")
  if (( rc != 0 )); then
    printf 'failed to parse tracked Kubernetes YAML while discovering HelmReleases: %s\n' \
      "${candidate_files[$index]}" >&2
    while IFS= read -r line; do
      printf '  %s\n' "$line" >&2
    done < "${tmpdir}/discover-${index}.err"
    exit 1
  fi
  cat "${tmpdir}/discover-${index}.out" >> "$helmrelease_files"
done
sort -u "$helmrelease_files" -o "$helmrelease_files"
while IFS= read -r file; do
  dirname "$file" >> "$apps_unsorted"
done < "$helmrelease_files"
sort -u "$apps_unsorted" | sed 's#^kubernetes/apps/##' > "$all_apps"
if [[ ! -s $all_apps ]]; then
  echo 'no tracked HelmRelease resources found' >&2
  exit 1
fi

shard_count=${HELM_IMAGE_SHARD_COUNT:-1}
shard_index=${HELM_IMAGE_SHARD_INDEX:-0}
[[ $shard_count =~ ^[1-9][0-9]*$ && $shard_index =~ ^[0-9]+$ ]] || {
  echo 'HELM_IMAGE_SHARD_COUNT must be positive and HELM_IMAGE_SHARD_INDEX must be non-negative' >&2
  exit 1
}
(( shard_index < shard_count )) || {
  printf 'HELM_IMAGE_SHARD_INDEX %s is outside shard count %s\n' "$shard_index" "$shard_count" >&2
  exit 1
}
app_count=$(awk 'END { print NR }' "$all_apps")
(( shard_count <= app_count )) || {
  printf 'HELM_IMAGE_SHARD_COUNT %s exceeds discovered application count %s\n' "$shard_count" "$app_count" >&2
  exit 1
}
awk -v count="$shard_count" -v shard="$shard_index" \
  '((NR - 1) % count) == shard' "$all_apps" > "$apps"

load_skip() {
  local target=$1 app
  skip_expected=''
  skip_reason=''
  while IFS=$'\t' read -r app expected_failure reason; do
    [[ -n $app && ${app:0:1} != '#' ]] || continue
    if [[ $app == "$target" ]]; then
      skip_expected=$expected_failure
      skip_reason=$reason
      [[ -n $skip_expected && -n $skip_reason ]] || {
        printf 'invalid Helm image validation skip entry for %s\n' "$target" >&2
        return 2
      }
      return 0
    fi
  done < "$skips"
  return 1
}

matches_expected_skip() {
  local log=$1 expected=$2 line seen=0
  while IFS= read -r line; do
    case "$line" in
      "$expected")
        seen=$((seen + 1))
        ;;
      '==> kustomize '*|'==> helm template '*|'warning: app contains ExternalSecret but ks.yaml does not depend on external-secrets-secret-store')
        ;;
      *)
        return 1
        ;;
    esac
  done < "$log"
  (( seen == 1 ))
}

workers=${HELM_IMAGE_JOBS:-12}
[[ $workers =~ ^[1-9][0-9]*$ ]] || {
  printf 'HELM_IMAGE_JOBS must be a positive integer: %s\n' "$workers" >&2
  exit 1
}

run_validation() {
  local app=$1 index=$2 rc
  if scripts/validate-app --offline "$app" > "${tmpdir}/validate-${index}.log" 2>&1; then
    rc=0
  else
    rc=$?
  fi
  printf '%s\n' "$rc" > "${tmpdir}/validate-${index}.rc"
}

index=0
while IFS= read -r app; do
  [[ -n $app ]] || continue
  run_validation "$app" "$index" &
  index=$((index + 1))
  if (( index % workers == 0 )); then
    wait
  fi
done < "$apps"
wait

status=0
index=0
while IFS= read -r app; do
  [[ -n $app ]] || continue
  log="${tmpdir}/validate-${index}.log"
  rc=$(< "${tmpdir}/validate-${index}.rc")

  found_unpinned=false
  while IFS= read -r line; do
    case "$line" in
      *': workload image is not digest pinned: '*)
        image=${line##*: workload image is not digest pinned: }
        printf '%s\t%s\n' "$app" "$image" >> "$actual"
        found_unpinned=true
        ;;
    esac
  done < "$log"

  has_skip=false
  if load_skip "$app"; then
    has_skip=true
  else
    skip_rc=$?
    if (( skip_rc == 2 )); then
      status=1
    fi
  fi

  if (( rc != 0 && rc != 3 )); then
    if [[ $has_skip == true ]] && matches_expected_skip "$log" "$skip_expected"; then
      printf 'warning: skipping expected Helm image render gap for %s: %s\n' "$app" "$skip_reason" >&2
    else
      printf 'Helm image rendering failed for %s' "$app" >&2
      if [[ $has_skip == true ]]; then
        printf ' with an unexpected failure; expected: %s' "$skip_expected" >&2
      fi
      printf ':\n' >&2
      while IFS= read -r line; do
        printf '  %s\n' "$line" >&2
      done < "$log"
      status=1
    fi
  elif (( rc == 3 )) && [[ $found_unpinned == false ]]; then
    printf 'Helm image validation for %s exited with image status but reported no unpinned image\n' "$app" >&2
    status=1
  elif (( rc == 0 )) && [[ $found_unpinned == true ]]; then
    printf 'Helm image validation for %s reported an unpinned image but exited successfully\n' "$app" >&2
    status=1
  elif [[ $has_skip == true ]]; then
    printf 'stale Helm image validation skip for %s (%s)\n' "$app" "$skip_reason" >&2
    status=1
  fi
  index=$((index + 1))
done < "$apps"

while IFS=$'\t' read -r skipped_app expected_failure reason; do
  [[ -n $skipped_app && ${skipped_app:0:1} != '#' ]] || continue
  if [[ -z $expected_failure || -z $reason ]]; then
    printf 'invalid Helm image validation skip entry: %s\n' "$skipped_app" >&2
    status=1
  elif ! grep -Fxq "$skipped_app" "$all_apps"; then
    printf 'Helm image validation skip no longer matches a tracked release directory: %s\n' "$skipped_app" >&2
    status=1
  fi
done < "$skips"

awk -F '\t' '
  NR == FNR { selected[$1] = 1; next }
  !/^(#|$)/ && selected[$1]
' "$apps" "$baseline" > "$expected"
sort -u "$actual" -o "$actual"
sort -u "$expected" -o "$expected"
if ! diff -u "$expected" "$actual"; then
  echo 'Rendered Helm image baseline changed. Pin new images rather than extending the baseline when the chart supports an override.' >&2
  status=1
fi

if (( status != 0 )); then
  exit "$status"
fi
printf 'ok: rendered Helm images match the explicit legacy baseline\n'
